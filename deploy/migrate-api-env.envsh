#!/bin/sh

# 兼容旧版本 Docker 环境变量：API_URL 同时作为两个新变量的兜底值。
DOCKER_LEGACY_API_URL_USED=false
if [ -n "$API_URL" ]; then
    DOCKER_LEGACY_API_URL_USED=true
fi

if [ "${DEFAULT_API_URL+x}" != "x" ]; then
    DEFAULT_API_URL=${API_URL:-https://zl.yyapi.cloud/v1}
fi
API_PROXY_URL=${API_PROXY_URL:-${API_URL:-https://zl.yyapi.cloud/v1}}
case "$API_PROXY_URL" in
    */v1) API_PROXY_URL="${API_PROXY_URL%/v1}" ;;
    */v1/) API_PROXY_URL="${API_PROXY_URL%/v1/}" ;;
esac

export DEFAULT_API_URL
export API_PROXY_URL
export DOCKER_LEGACY_API_URL_USED
